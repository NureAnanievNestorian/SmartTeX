DB_ENGINE=postgres
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,web,mcp,.ngrok-free.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000
TIME_ZONE=Europe/Kyiv
POSTGRES_DB=smarttex
POSTGRES_USER=smarttex
POSTGRES_PASSWORD=smarttex
POSTGRES_HOST=db
POSTGRES_PORT=5432
WEB_PORT=8000
DOCKER_SOCK_PATH=/var/run/docker.sock
LATEX_STRICT_ERRORS=False
DJANGO_API_BASE_URL=http://web:8000
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=9000
MCP_PATH=/mcp
MCP_PUBLIC_BASE_URL=http://localhost:8000
MCP_CORS_ORIGINS=*
HOST_PROJECT_ROOT=/absolute/path/to/SmartTeX
OAUTH_ISSUER_URL=http://localhost:8000
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_INTROSPECTION_SECRET=replace-with-random-secret
MCP_OAUTH_ENABLED=True
MCP_SERVER_PUBLIC_URL=http://localhost:9000
WEB_PUBLIC_BASE_URL=http://localhost:8000
MCP_AUTH_SERVER_ISSUER_URL=http://localhost:8000
MCP_INTROSPECTION_URL=http://web:8000/oauth/introspect/
MCP_INTROSPECTION_SECRET=replace-with-random-secret
MAILJET_SMTP_HOST=in-v3.mailjet.com
MAILJET_SMTP_PORT=587
MAILJET_API_KEY=replace-with-mailjet-api-key
MAILJET_SECRET_KEY=replace-with-mailjet-secret-key
MAILJET_SMTP_TLS=True
MAIL_FROM_EMAIL=noreply@smart-tex.pp.ua
EMAIL_VERIFICATION_TTL_HOURS=24
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback/
